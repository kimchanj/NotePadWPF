<Window x:Class="NotePadWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Closing="MainWindow_Closing"
        Title="WinMemo"
        Width="1200"
        Height="800"
        MinWidth="900"
        MinHeight="600">
    <Window.Resources>
        <Style x:Key="TabCloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="19" />
            <Setter Property="Height" Value="19" />
            <Setter Property="Margin" Value="6,0,0,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#7A7A7A" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="CloseButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CloseButtonBorder" Property="Background" Value="#E6E6E6" />
                                <Setter Property="Foreground" Value="#4A4A4A" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="CloseButtonBorder" Property="Background" Value="#D2D2D2" />
                                <Setter Property="Foreground" Value="#2F2F2F" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="TabHeaderTemplate">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding DisplayHeader}"
                           VerticalAlignment="Center"
                           Margin="0,0,1,0" />
                <Button Content="X"
                        Style="{StaticResource TabCloseButtonStyle}"
                        Click="TabCloseButton_Click"
                        Tag="{Binding RelativeSource={RelativeSource AncestorType=TabItem}}" />
            </StackPanel>
        </DataTemplate>

        <Style x:Key="WinMemoTabItemStyle" TargetType="TabItem">
            <Setter Property="HeaderTemplate" Value="{StaticResource TabHeaderTemplate}" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Foreground" Value="#666666" />
            <Setter Property="FontWeight" Value="Normal" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="#1F1F1F" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Menu Grid.Row="0">
            <MenuItem Header="파일(_F)">
                <MenuItem Header="새로 만들기" InputGestureText="Ctrl+N" Click="NewTabMenuItem_Click" />
                <MenuItem Header="열기" InputGestureText="Ctrl+O" Click="OpenMenuItem_Click" />
                <MenuItem Header="저장" InputGestureText="Ctrl+S" Click="SaveMenuItem_Click" />
                <MenuItem Header="다른 이름으로 저장" InputGestureText="Ctrl+Shift+S" Click="SaveAsMenuItem_Click" />
                <Separator />
                <MenuItem Header="종료" InputGestureText="Alt+F4" Click="ExitMenuItem_Click" />
            </MenuItem>

            <MenuItem Header="편집(_E)">
                <MenuItem Header="실행 취소" InputGestureText="Ctrl+Z" Click="UndoMenuItem_Click" />
                <MenuItem Header="다시 실행" InputGestureText="Ctrl+Y" Click="RedoMenuItem_Click" />
                <Separator />
                <MenuItem Header="잘라내기" InputGestureText="Ctrl+X" Click="CutMenuItem_Click" />
                <MenuItem Header="복사" InputGestureText="Ctrl+C" Click="CopyMenuItem_Click" />
                <MenuItem Header="붙여넣기" InputGestureText="Ctrl+V" Click="PasteMenuItem_Click" />
                <MenuItem Header="모두 선택" InputGestureText="Ctrl+A" Click="SelectAllMenuItem_Click" />
                <Separator />
                <MenuItem Header="찾기" InputGestureText="Ctrl+F" Click="FindMenuItem_Click" />
                <MenuItem Header="바꾸기" InputGestureText="Ctrl+H" Click="ReplaceMenuItem_Click" />
            </MenuItem>

            <MenuItem Header="보기(_V)">
                <MenuItem x:Name="WordWrapMenuItem"
                          Header="자동 줄바꿈"
                          IsCheckable="True"
                          Click="WordWrapMenuItem_Click" />
                <MenuItem x:Name="StatusBarMenuItem"
                          Header="상태 표시줄"
                          IsCheckable="True"
                          IsChecked="True"
                          Click="StatusBarMenuItem_Click" />
            </MenuItem>

            <MenuItem Header="도움말(_H)">
                <MenuItem Header="정보" Click="AboutMenuItem_Click" />
            </MenuItem>
        </Menu>

        <DockPanel Grid.Row="1">
            <Border x:Name="FindReplacePanel"
                    DockPanel.Dock="Top"
                    Visibility="Collapsed"
                    Background="#F4F4F4"
                    BorderBrush="#D0D0D0"
                    BorderThickness="0,0,0,1"
                    Padding="8">
                <StackPanel>
                    <WrapPanel VerticalAlignment="Center">
                        <TextBlock Text="찾기:"
                                   VerticalAlignment="Center"
                                   Margin="0,0,6,0" />
                        <TextBox x:Name="FindTextBox"
                                 Width="220"
                                 Margin="0,0,8,0"
                                 KeyDown="FindTextBox_KeyDown" />
                        <CheckBox x:Name="MatchCaseCheckBox"
                                  Content="Match Case"
                                  VerticalAlignment="Center"
                                  Margin="0,0,8,0" />
                        <Button Content="Find Next"
                                Width="88"
                                Margin="0,0,8,0"
                                Click="FindNextButton_Click" />
                        <Button Content="닫기"
                                Width="60"
                                Click="CloseFindReplacePanelButton_Click" />
                    </WrapPanel>

                    <WrapPanel x:Name="ReplaceRowPanel"
                               Margin="0,8,0,0"
                               VerticalAlignment="Center">
                        <TextBlock Text="바꾸기:"
                                   VerticalAlignment="Center"
                                   Margin="0,0,6,0" />
                        <TextBox x:Name="ReplaceTextBox"
                                 Width="220"
                                 Margin="0,0,8,0" />
                        <Button Content="Replace"
                                Width="88"
                                Margin="0,0,8,0"
                                Click="ReplaceButton_Click" />
                        <Button Content="Replace All"
                                Width="88"
                                Click="ReplaceAllButton_Click" />
                    </WrapPanel>
                </StackPanel>
            </Border>

            <TabControl x:Name="EditorTabControl"
                        ItemContainerStyle="{StaticResource WinMemoTabItemStyle}"
                        SelectionChanged="EditorTabControl_SelectionChanged" />
        </DockPanel>

        <StatusBar x:Name="MainStatusBar" Grid.Row="2">
            <StatusBarItem HorizontalContentAlignment="Stretch">
                <Grid Width="{Binding ActualWidth, ElementName=RootGrid}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Ready" VerticalAlignment="Center" />
                    <TextBlock x:Name="StatusPositionTextBlock"
                               Grid.Column="1"
                               Text="Ln 1, Col 1 | UTF-8 | CRLF | 100%"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Right" />
                </Grid>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
